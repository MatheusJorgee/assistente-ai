# ============================================================================
# .env.example
# Copie para backend/.env e preencha os valores
# ============================================================================

# ============================================================================
# Google Gemini API
# ============================================================================
# Obter em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua-chave-api-aqui
GEMINI_MODEL=gemini-1.5-pro

# Modelos alternativos (se quiser testar):
# GEMINI_MODEL=gemini-2.0-flash      # Mais rápido, menos preciso
# GEMINI_MODEL=gemini-1.5-flash      # Balanço entre speed/accuracy

# ============================================================================
# Spotify API (opcional)
# ============================================================================
# Obter em: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8080

# ============================================================================
# Segurança e Comportamento
# ============================================================================
# Profiles: trusted-local (permissivo), strict (restritivo)
QUINTA_SECURITY_PROFILE=trusted-local

# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# WebSocket (opcional - defaults funcionam em localhost)
# ============================================================================
# Estas variáveis sobrem em: frontend/.env.local ou Vercel
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/chat
NEXT_PUBLIC_WS_HOST=localhost
NEXT_PUBLIC_WS_PORT=8000
NEXT_PUBLIC_WS_PATH=/ws/chat

# ============================================================================
# Debug (opcional)
# ============================================================================
NEXT_PUBLIC_DEBUG=false

# ============================================================================
# NOTAS IMPORTANTES
# ============================================================================
#
# 1. GEMINI_API_KEY é OBRIGATÓRIO
#    - Sem ela, o Brain não inicializa
#    - Gerar em: https://aistudio.google.com/app/apikey
#
# 2. Para desenvolvimento local
#    - Use NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/chat
#
# 3. Para deploy Vercel + Backend Local (via ngrok)
#    - Obter URL ngrok: ngrok http 8000
#    - Adicionar em Vercel: NEXT_PUBLIC_WS_URL=wss://xxx.ngrok.io/ws/chat
#    - (Note: wss:// para HTTPS)
#
# 4. NÃO commitar este arquivo com valores reais
#    - Use: git update-index --assume-unchanged backend/.env
#    - Ou adicione em .gitignore
#
# ============================================================================
